---
import background from '../assets/background.svg';

const conferences = [
	{
		name: 'PHPerKaigi 2026',
		siteUrl: 'https://phperkaigi.jp/2026',
		supportName: 'U-23',
		supportUrl: 'https://fortee.jp/phperkaigi-2026/ticket-shop/index',
		deadline: '2026/03/22 15:00:00',
		eventDate: '2026/03/20〜03/22',
	},
	{
		name: 'Laravel Live Japan',
		siteUrl: 'https://laravellive.jp',
		supportName: '無料チケット',
		supportUrl: 'https://frequent-pick-a8d.notion.site/2f43f372b48080b88821ec92c32ec6f6',
		deadline: '締め切り次第',
		eventDate: '2026/05/26〜05/27',
	},
	{
		name: 'フロントエンドカンファレンス名古屋 2026',
		siteUrl: 'https://fortee.jp/fec-nagoya-2026',
		supportName: '学生支援(東海地方学生向け)',
		supportUrl: 'https://fortee.jp/fec-nagoya-2026/ticket-shop/index',
		deadline: '運営へ確認',
		eventDate: '2026/05/09',
	},
	{
		name: 'スクラムフェス金沢 2026',
		siteUrl: 'https://www.scrumfestkanazawa.org',
		supportName: '学生向けチケット',
		supportUrl: 'https://pretix.eu/scrumkanazawa/2026',
		deadline: '売り切れ次第',
		eventDate: '2026/06/19〜06/20',
	},
];
---

<div id="container">
	<img id="background" src={background.src} alt="" fetchpriority="high" />

	<main class="page">
		<section class="hero box">
			<div class="hero-copy">
				<p class="eyebrow">Japanese IT Conferences With Support</p>
				<h1>参加支援がある日本のITカンファレンス</h1>
				<p class="lead">参加支援や学生向けチケットのあるカンファレンスを、ひと目で追える形でまとめています。</p>
			</div>

			<div class="hero-meta">
				<p class="current-time-label">現在時刻</p>
				<p class="current-time" data-current-time>--</p>
				<div class="action-row">
					<a
						class="button"
						href="https://github.com/You-saku/japanese-it-conferences-with-support"
						target="_blank"
						rel="noopener noreferrer"
					>
						GitHub
					</a>
					<a
						class="subtle-link"
						href="https://github.com/You-saku/japanese-it-conferences-with-support/issues"
						target="_blank"
						rel="noopener noreferrer"
					>
						追加・修正を送る
					</a>
				</div>
			</div>
		</section>

		<section class="table-card box">
			<div class="section-heading">
				<h2>募集中の支援一覧</h2>
				<p>公式ページと支援詳細へのリンクをそのままたどれます。</p>
			</div>

			<div class="table-wrap">
				<table>
					<thead>
						<tr>
							<th>カンファレンス名</th>
							<th>公式ページ</th>
							<th>支援名</th>
							<th>支援詳細</th>
							<th>支援応募の締切</th>
							<th>カンファレンス開催時期</th>
						</tr>
					</thead>
					<tbody>
						{
							conferences.map((conference) => (
								<tr>
									<td>{conference.name}</td>
									<td>
										<a href={conference.siteUrl} target="_blank" rel="noreferrer">
											{conference.siteUrl}
										</a>
									</td>
									<td>{conference.supportName}</td>
									<td>
										<a href={conference.supportUrl} target="_blank" rel="noreferrer">
											{conference.supportUrl}
										</a>
									</td>
									<td>{conference.deadline}</td>
									<td>{conference.eventDate}</td>
								</tr>
							))
						}
					</tbody>
				</table>
			</div>
		</section>
	</main>
</div>

<script>
	const formatter = new Intl.DateTimeFormat('ja-JP', {
		dateStyle: 'full',
		timeStyle: 'medium',
		timeZone: 'Asia/Tokyo',
	});

	const timeNode = document.querySelector('[data-current-time]');
	if (timeNode) {
		const updateCurrentTime = () => {
			timeNode.textContent = formatter.format(new Date());
		};

		updateCurrentTime();
		window.setInterval(updateCurrentTime, 1000);
	}
</script>

<style>
	:root {
		--text-strong: #111827;
		--text-muted: #4b5563;
		--surface: rgba(255, 255, 255, 0.82);
		--surface-strong: rgba(255, 255, 255, 0.94);
		--border-soft: rgba(255, 255, 255, 0.7);
		--shadow-soft: 0 24px 80px rgba(129, 28, 103, 0.12);
		--accent-start: #3245ff;
		--accent-end: #bc52ee;
	}

	#background {
		position: fixed;
		inset: 0;
		width: 100%;
		height: 100%;
		z-index: -1;
		filter: blur(100px);
	}

	#container {
		font-family:
			Inter, 'Hiragino Kaku Gothic ProN', 'Yu Gothic', 'Meiryo', 'Helvetica Neue', Arial,
			sans-serif;
		min-height: 100%;
		color: var(--text-strong);
	}

	.page {
		max-width: 1180px;
		margin: 0 auto;
		padding: 56px 20px 40px;
		display: grid;
		gap: 24px;
	}

	.box {
		background: var(--surface);
		border: 1px solid var(--border-soft);
		border-radius: 24px;
		backdrop-filter: blur(40px);
		box-shadow: var(--shadow-soft);
	}

	.hero {
		display: grid;
		gap: 24px;
		padding: 32px;
		align-items: end;
	}

	.eyebrow {
		margin: 0 0 12px;
		font-size: 0.85rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: #7c3aed;
	}

	h1 {
		margin: 0;
		font-size: clamp(2rem, 4vw, 3.4rem);
		line-height: 1.15;
		letter-spacing: -0.03em;
	}

	.lead,
	.section-heading p {
		margin: 14px 0 0;
		font-size: 1rem;
		line-height: 1.7;
		color: var(--text-muted);
	}

	.hero-meta {
		padding: 20px;
		border-radius: 20px;
		background: var(--surface-strong);
		border: 1px solid rgba(255, 255, 255, 0.88);
	}

	.current-time-label {
		margin: 0;
		font-size: 0.85rem;
		color: var(--text-muted);
	}

	.current-time {
		margin: 6px 0 0;
		font-size: 1.1rem;
		font-weight: 700;
		line-height: 1.5;
	}

	.action-row {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
		margin-top: 20px;
	}

	.button,
	.subtle-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 12px 16px;
		border-radius: 12px;
		text-decoration: none;
		transition:
			transform 0.2s ease,
			box-shadow 0.2s ease,
			color 0.2s ease;
	}

	.button {
		color: white;
		background: linear-gradient(83.21deg, var(--accent-start) 0%, var(--accent-end) 100%);
		box-shadow:
			inset 0 0 0 1px rgba(255, 255, 255, 0.12),
			inset 0 -2px 0 rgba(0, 0, 0, 0.2);
	}

	.subtle-link {
		color: var(--text-strong);
		background: rgba(255, 255, 255, 0.75);
	}

	.button:hover,
	.subtle-link:hover {
		transform: translateY(-1px);
	}

	.table-card {
		padding: 24px;
	}

	.section-heading {
		margin-bottom: 18px;
	}

	h2 {
		margin: 0;
		font-size: 1.35rem;
	}

	.table-wrap {
		overflow-x: auto;
		border-radius: 18px;
	}

	table {
		width: 100%;
		border-collapse: collapse;
		min-width: 920px;
		background: rgba(255, 255, 255, 0.72);
	}

	th,
	td {
		padding: 14px 16px;
		text-align: left;
		vertical-align: top;
		border-bottom: 1px solid rgba(203, 213, 225, 0.7);
	}

	th {
		font-size: 0.92rem;
		background: rgba(248, 250, 252, 0.92);
	}

	td {
		font-size: 0.96rem;
		line-height: 1.6;
		color: var(--text-muted);
	}

	a {
		color: #4338ca;
		word-break: break-word;
	}

	@media (max-width: 900px) {
		.page {
			padding-top: 24px;
		}

		.hero {
			grid-template-columns: 1fr;
			padding: 24px;
		}
	}

	@media (max-width: 640px) {
		.table-card {
			padding: 18px;
		}

		th,
		td {
			padding: 12px;
		}
	}
</style>
